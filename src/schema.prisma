CREATE TABLE users (id uuid PRIMARY KEY, email text, created_at timestamptz DEFAULT now()); CREATE TABLE calendar_events (id uuid PRIMARY KEY, user_id uuid REFERENCES users(id), date date, title text, description text, type text CHECK (type IN ('holiday', 'rosh_chodesh', 'custom')), created_at timestamptz DEFAULT now()); CREATE TABLE user_settings (id uuid PRIMARY KEY, user_id uuid REFERENCES users(id), language_preference text DEFAULT 'bilingual', notification_enabled boolean DEFAULT false, created_at timestamptz DEFAULT now());